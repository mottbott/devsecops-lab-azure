# Copy this file to terraform.tfvars and fill in the real values.
# terraform.tfvars is gitignored; this example file is not.

# === Required: Azure-Kontext ===
# subscription_id = "00000000-0000-0000-0000-000000000000"
# tenant_id       = "00000000-0000-0000-0000-000000000000"
# owner_email     = "you@example.com"

# === Optional: Region und Namensbestandteile ===
# location       = "westeurope"
# location_short = "weu"
# environment    = "dev"

# === Optional: Sicherheitsparameter ===
# allowed_ingress_ips = ["198.51.100.7/32"]

# === Optional: Kostenkontrolle ===
# log_retention_days = 30
# log_daily_cap_gb   = 1

# === Tags ===
# tags_additional = {
#   cost_center = "lab"
# }
